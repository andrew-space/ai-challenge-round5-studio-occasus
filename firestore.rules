rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminClaim() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isAdminEmail() {
      return isSignedIn() &&
        request.auth.token.email is string &&
        request.auth.token.email.matches('^(andrew\\.neuburger@community\\.isunet\\.edu|andrew\\.neuburger@isunet\\.edu|andrewneuburger67@gmail\\.com)$');
    }

    function isAdmin() {
      return isAdminClaim() || isAdminEmail();
    }

    match /users/{uid} {
      allow read: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if (isSignedIn() && request.auth.uid == uid &&
        (
          request.resource.data.isPro == resource.data.isPro ||
          isAdminClaim()
        )) || isAdmin();

      match /clarity_versions/{versionId} {
        allow read, write: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      }
    }

    match /usage/{uid} {
      allow read, write: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /stripe_events/{eventId} {
      allow read, write: if false;
    }
  }
}
